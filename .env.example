# Timezone (e.g. America/Los_Angeles, Europe/Madrid, UTC)
TZ=UTC

# Port to expose the WUD dashboard on (host side)
WUD_PORT=4012

# How often WUD scans registries for new images.
# 6-field cron: "second minute hour day-of-month month day-of-week".
# Default = every 6 hours.
WUD_CRON=0 0 */6 * * *

# --- Control panel (Backup now / Update buttons) ---
# Port for the panel UI
PANEL_PORT=4013
# The compose project the panel should manage/back up. Mounted at the SAME path
# inside the panel container so `docker compose` resolves bind paths correctly.
# Point this at YOUR stack, e.g. /home/me/docker
PROJECT_DIR=/home/me/docker
# Optional: require a token on the panel (open http://host:4013/?token=...)
PANEL_TOKEN=
